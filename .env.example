# Server
PORT=4000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/personal_drive

# Auth
# AUTH_STRATEGY=local  -> verify JWT tại chỗ bằng JWT_SECRET (yêu cầu auth microservice ký cùng secret)
# AUTH_STRATEGY=api    -> gọi API AUTH_API_BASE_URL/auth/checkToken để verify mỗi request
AUTH_STRATEGY=local
JWT_SECRET=change_me_to_shared_secret
AUTH_API_BASE_URL=https://file.quockhanh020924.id.vn

# Cookie xác thực cho client web (EJS). Mobile/API client vẫn dùng header
# Authorization: Bearer <token>, không liên quan đến cookie này.
COOKIE_NAME=drive_token
# Để trống nếu web và backend chạy cùng domain/subdomain không cần chia sẻ cookie.
# Điền vd ".quockhanh020924.id.vn" nếu cần cookie dùng chung giữa các subdomain.
COOKIE_DOMAIN=
# Bật true khi chạy production qua HTTPS
COOKIE_SECURE=false
COOKIE_MAX_AGE_DAYS=7

# Cloudflare R2
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=personal-drive
# Thời gian sống (giây) của presigned URL
R2_UPLOAD_URL_EXPIRES_IN=300
R2_DOWNLOAD_URL_EXPIRES_IN=3600
